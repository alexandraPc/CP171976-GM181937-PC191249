<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FB">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top App Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical"
                android:background="#F7F9FB">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_placeholder"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="#FFFFFF"
                    android:padding="8dp"
                    android:scaleType="centerInside" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Ledger"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_dialog_info"
                    android:tint="#0D1B2A"
                    android:padding="8dp"
                    android:scaleType="centerInside" />
            </LinearLayout>

            <!-- Total Savings Progress Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#002446"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL EN AHORROS"
                        android:textSize="10sp"
                        android:textColor="#8BAFC8"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvTotalSaved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="16dp" />

                    <ProgressBar
                        android:id="@+id/progressTotalSavings"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:progressDrawable="@drawable/progress_green_goal"
                        android:max="100"
                        android:progress="0"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvSavingsPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0% del total de metas"
                        android:textSize="12sp"
                        android:textColor="#8BAFC8" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Featured Goal Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFeaturedGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvPrimaryTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="META PRINCIPAL"
                        android:textSize="10sp"
                        android:textColor="#1B6D24"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_primary_tag"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvFeaturedGoalName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre de Meta"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#002446"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvFeaturedGoalSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date • Category"
                        android:textSize="13sp"
                        android:textColor="#8A9BB0"
                        android:layout_marginBottom="16dp" />

                    <!-- Image placeholder with progress overlay -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:background="@drawable/bg_goal_gradient"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvFeaturedProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0 / $0 — 0%"
                            android:textSize="14sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:background="#88000000"
                            android:layout_gravity="bottom|start"
                            android:layout_margin="12dp" />
                    </FrameLayout>

                    <!-- Action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnAddToFeaturedGoal"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="Agregar a Meta"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#002446"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btnMoreOptions"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="..."
                            android:textColor="#5A6B7B"
                            android:backgroundTint="#E8EDF2"
                            android:padding="0dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Other Goals Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTRAS METAS"
                android:textSize="10sp"
                android:textColor="#8A9BB0"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp" />

            <!-- Mini Goals RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGoals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- New Piggy Bank Card (dashed) -->
            <LinearLayout
                android:id="@+id/llNewGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_dashed_card"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:textSize="24sp"
                        android:textColor="#002446"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_placeholder" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nueva Alcancía"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crea una nueva meta de ahorro"
                    android:textSize="13sp"
                    android:textColor="#8A9BB0" />
            </LinearLayout>

            <!-- Savings Velocity Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VELOCIDAD DE AHORRO"
                    android:textSize="10sp"
                    android:textColor="#8A9BB0"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvVelocityAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+$0 prom/mes"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#002446"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvVelocityDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Basado en tu actividad de ahorro"
                    android:textSize="13sp"
                    android:textColor="#8A9BB0"
                    android:layout_marginBottom="16dp" />

                <!-- Static bar chart (5 bars) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="#D3E3FF" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="#A0C4FF" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="#D3E3FF" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="#002446" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:background="#D3E3FF" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/dash_card"
        app:itemIconTint="@color/dash_text_secondary"
        app:itemTextColor="@color/dash_text_secondary"
        app:menu="@menu/bottom_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
