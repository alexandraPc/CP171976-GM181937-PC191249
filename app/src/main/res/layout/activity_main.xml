<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="64dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top App Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_placeholder"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="@color/white"
                    android:padding="8dp"
                    android:scaleType="centerInside" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Ledger"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/dash_text_primary" />

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/stat_notify_more"
                    android:tint="@color/dash_text_primary" />
            </LinearLayout>

            <!-- Total Net Worth -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL NET WORTH"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/dash_text_secondary" />

                <TextView
                    android:id="@+id/tvNetWorth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    android:textColor="@color/dash_text_primary"
                    android:layout_marginTop="2dp"
                    tools:text="$142,850.00" />
            </LinearLayout>

            <!-- Overall Status Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/dash_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overall Status"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/dash_text_primary" />

                    <TextView
                        android:id="@+id/tvStatusDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Track your income and expenses to see your financial overview."
                        android:textSize="13sp"
                        android:textColor="@color/dash_text_secondary"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical">

                        <!-- Traffic light circles -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvStatusGreen"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:text="✓"
                                android:textSize="22sp"
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:background="@drawable/bg_status_green" />

                            <TextView
                                android:id="@+id/tvStatusAmber"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:text="⚠"
                                android:textSize="20sp"
                                android:textColor="@color/dash_amber"
                                android:gravity="center"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_status_amber" />

                            <TextView
                                android:id="@+id/tvStatusRed"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:text="✕"
                                android:textSize="20sp"
                                android:textColor="@color/dash_red"
                                android:gravity="center"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_status_red" />
                        </LinearLayout>

                        <!-- Status label -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tvStatusLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Stable &amp; Optimal"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/dash_green"
                                android:gravity="end" />

                            <TextView
                                android:id="@+id/tvLastUpdated"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Last updated just now"
                                android:textSize="11sp"
                                android:textColor="@color/dash_text_secondary"
                                android:gravity="end" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp"
                android:baselineAligned="false">

                <!-- Daily Average -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/dash_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DAILY AVERAGE"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:textColor="@color/dash_text_secondary" />

                        <TextView
                            android:id="@+id/tvDailyAverage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/dash_text_primary"
                            android:layout_marginTop="8dp"
                            tools:text="$84.20" />

                        <TextView
                            android:id="@+id/tvDailyTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↓ 4%"
                            android:textSize="12sp"
                            android:textColor="@color/dash_green"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Monthly Commitments -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/dash_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MONTHLY COMMITMENTS"
                            android:textSize="10sp"
                            android:letterSpacing="0.1"
                            android:textColor="@color/dash_text_secondary" />

                        <TextView
                            android:id="@+id/tvMonthlyCommitments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/dash_text_primary"
                            android:layout_marginTop="8dp"
                            tools:text="$2,450" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="On Track"
                            android:textSize="12sp"
                            android:textColor="@color/dash_text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Free Money Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/dash_card_blue"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Free Money"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/dash_text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Disposable income remaining after all scheduled liabilities and savings goals."
                        android:textSize="12sp"
                        android:textColor="@color/dash_text_secondary"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/tvFreeMoney"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="$0.00"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="@color/dash_text_primary"
                            tools:text="$1,120.00" />

                        <TextView
                            android:id="@+id/tvProgressPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0% OF\nMONTHLY\nBUDGET"
                            android:textSize="10sp"
                            android:textColor="@color/dash_text_secondary"
                            android:letterSpacing="0.05"
                            android:gravity="end" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressFreeMoney"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_free_money" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:id="@+id/tvProgressSpent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="$0.00 Spent"
                            android:textSize="10sp"
                            android:textColor="@color/dash_text_muted" />

                        <TextView
                            android:id="@+id/tvProgressTarget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00 Target"
                            android:textSize="10sp"
                            android:textColor="@color/dash_text_muted" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent Activity -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Activity"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/dash_text_primary" />

                    <TextView
                        android:id="@+id/btnVerTodo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Full Ledger"
                        android:textSize="13sp"
                        android:textColor="@color/dash_link"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTransacciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/dash_card"
        app:itemIconTint="@color/dash_text_secondary"
        app:itemTextColor="@color/dash_text_secondary"
        app:menu="@menu/bottom_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
