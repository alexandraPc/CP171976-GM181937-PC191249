<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/imgGoalIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_white_rounded"
                android:src="@drawable/ic_meta"
                android:padding="10dp"
                android:tint="#002446"
                android:scaleType="centerInside" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGoalName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre de Meta"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A" />

                <TextView
                    android:id="@+id/tvGoalProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% COMPLETADO"
                    android:textSize="10sp"
                    android:textColor="#8A9BB0"
                    android:letterSpacing="0.05" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressGoal"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progressDrawable="@drawable/progress_amber_goal"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnAddToGoal"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Agregar a Meta"
            android:textSize="13sp"
            android:textColor="#002446"
            android:backgroundTint="@android:color/transparent" />

        <TextView
            android:id="@+id/tvGoalAchieved"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Meta Alcanzada"
            android:textSize="13sp"
            android:textColor="#1B6D24"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_goal_achieved"
            android:visibility="gone" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
