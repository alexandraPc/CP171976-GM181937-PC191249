<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_transaction_item">

    <!-- Category icon -->
    <ImageView
        android:id="@+id/imgCategoria"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_icon_white_rounded"
        android:src="@android:drawable/ic_menu_agenda"
        android:tint="@color/primary_blue"
        android:padding="10dp"
        android:scaleType="centerInside" />

    <!-- Name + category -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtConcepto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            tools:text="Apple Store Online" />

        <TextView
            android:id="@+id/txtCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#8AAEC9"
            android:layout_marginTop="2dp"
            tools:text="Electronics &amp; Utility" />
    </LinearLayout>

    <!-- Amount + date -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/txtMonto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FF5252"
            tools:text="-$129.00" />

        <TextView
            android:id="@+id/txtFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#8AAEC9"
            android:layout_marginTop="2dp"
            tools:text="Today" />
    </LinearLayout>
</LinearLayout>
